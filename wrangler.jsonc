{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "palo-wire",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-07",
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "silicon.yulu34.top",
      "custom_domain": true
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SIGNAL_CACHE",
      "id": "ea2cafd2392c42c9a8705b1cacfb4650"
    }
  ],
  "triggers": {
    "crons": [
      "0 */3 * * *"
    ]
  }
}
